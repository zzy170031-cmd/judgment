{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://judgment.local/schemas/worker-packet.schema.json",
  "title": "Judgment Worker Packet",
  "type": "object",
  "required": [
    "id",
    "project",
    "lane",
    "agent",
    "goal",
    "inputs",
    "allowedActions",
    "forbiddenActions",
    "oracles",
    "downstreamReceiver",
    "stopCondition",
    "review"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "project": { "type": "string", "minLength": 1 },
    "lane": { "type": "string", "minLength": 1 },
    "agent": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "allowedActions": { "type": "array", "items": { "type": "string" } },
    "forbiddenActions": { "type": "array", "items": { "type": "string" } },
    "oracles": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "worktree": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "path": { "type": "string" },
        "branch": { "type": "string" },
        "baseRef": { "type": "string" }
      }
    },
    "downstreamReceiver": { "type": "string", "minLength": 1 },
    "stopCondition": { "type": "string", "minLength": 1 },
    "review": {
      "type": "object",
      "required": ["required", "receiver", "status"],
      "properties": {
        "required": { "type": "boolean" },
        "receiver": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "not-required", "passed", "failed", "blocked"] }
      }
    }
  }
}
